# Host port published by Docker on the VPS.
BOT_API_BIND_IP=0.0.0.0
BOT_API_PORT=8082

# HTTP server inside the container.
REVIEW_API_HOST=0.0.0.0
REVIEW_API_PORT=8081

# API auth and browser CORS policy.
REVIEW_API_BEARER_TOKEN=change_me_review_api_bearer_token
REVIEW_API_ALLOWED_ORIGINS=

# Runtime settings.
ENVIRONMENT=production
LOG_LEVEL=INFO
DATABASE_PATH=data/bot.sqlite3
DATA_DIR=data
